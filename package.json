{
  "name": "sf-boost-chrome",
  "description": "Salesforce productivity toolkit for admins and developers",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "author": "nocebov",
  "repository": {
    "type": "git",
    "url": "https://github.com/nocebov/sf-boost-chrome.git"
  },
  "homepage": "https://github.com/nocebov/sf-boost-chrome#readme",
  "bugs": {
    "url": "https://github.com/nocebov/sf-boost-chrome/issues"
  },
  "keywords": [
    "salesforce",
    "chrome-extension",
    "productivity",
    "admin",
    "developer",
    "wxt",
    "manifest-v3"
  ],
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:reload": "bun run build && bun run scripts/reload-extension.ts",
    "zip": "wxt zip",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "bun run scripts/smoke-test.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "puppeteer-core": "^24.6.1",
    "selfsigned": "^3.0.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "wxt": "^0.20.0"
  }
}
