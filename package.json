    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "puppeteer-core": "^24.6.1",
    "selfsigned": "^3.0.1",
    "typescript": "^5.8.0",
    "wxt": "^0.20.0"
  }
}
